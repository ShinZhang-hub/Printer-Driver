*FileVersion: "2.6"
*FormatVersion: "4.3"
*LanguageEncoding: ISOLatin1
*LanguageVersion: English
*Manufacturer: "FF"
*PCFileName: "FFPDMX01.PPD"
*Product: "(Print Driver for Mac OS X)"
*PSVersion: "(3015.104) 1"
*ShortNickName: "FF Print Driver for Mac OS X"
*ModelName: "FF Print Driver for Mac OS X"
*NickName: "FF Print Driver for Mac OS X v2.6"
*cupsFilter: "application/pdf 0 /Library/Printers/FUJIFILM/Filter/FFACMMCFilter"
*FFXPrintTypeSettings: "Default03-Type16"
*FFXAccountingSettings: "Default04-Type08"
*FFXFeaturesSettings: "Default01"
*FFXLayoutSettings: "Default00-Type02"
*APDialogExtension: "/Library/Printers/FUJIFILM/PDEs/FFACMMAccount.plugin"
*APDialogExtension: "/Library/Printers/FUJIFILM/PDEs/FFACMMFeatures.plugin"
*cupsSNMPSuppliles: False
*cupsSingleFile:True
*JobPatchFile 0: ""

*% === Options and Constraints =========
*OpenGroup: InstallableOptions/Options Installed
*OpenUI *FFMinDigitPasscode/Minimum Passcode Length: PickOne
*DefaultFFMinDigitPasscode: 0
